<mujoco model="rover_arm">
  <compiler angle="radian"/>

  <option gravity="0 0 -9.81" timestep="0.01"/>

  <default>
    <joint damping="1.0" armature="0.1"/>
    <geom condim="3" friction="1 0.5 0.01"/>
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="8 8" reflectance="0.2"/>
    <material name="arm_mat" rgba="0.6 0.6 0.7 1"/>
    <material name="claw_mat" rgba="0.8 0.3 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular="0.3 0.3 0.3"/>
    <light pos="1 1 2" dir="-0.5 -0.5 -1" diffuse="0.5 0.5 0.5"/>

    <geom type="plane" size="2 2 0.01" material="grid_mat"/>

    <!-- Base rail: runs along X axis -->
    <body name="base" pos="0 0 0.05">
      <geom type="box" size="0.6 0.05 0.03" rgba="0.4 0.4 0.4 1" mass="5"/>

      <!-- Sliding carriage: slides along X -->
      <body name="carriage" pos="0 0 0.05">
        <joint name="base_slide" type="slide" axis="1 0 0" range="-0.5 0.5" damping="2.0"/>
        <geom type="box" size="0.06 0.06 0.04" material="arm_mat" mass="2"/>

        <!-- Upper arm: extends upward along Z, shoulder rotates around X
             so the arm swings in the Y-Z plane (perpendicular to the slide) -->
        <body name="upper_arm" pos="0 0 0.04">
          <joint name="shoulder" type="hinge" axis="1 0 0" range="-1.5708 1.5708" damping="1.5"/>
          <geom type="capsule" fromto="0 0 0 0 0 0.3" size="0.025" material="arm_mat" mass="1"/>

          <!-- Forearm: continues along Z, elbow also rotates around X -->
          <body name="forearm" pos="0 0 0.3">
            <joint name="elbow" type="hinge" axis="1 0 0" range="0 2.6" damping="1.5"/>
            <geom type="capsule" fromto="0 0 0 0 0 0.25" size="0.02" material="arm_mat" mass="0.8"/>

            <!-- Wrist: twist around the arm's long axis (Z) -->
            <body name="wrist" pos="0 0 0.25">
              <joint name="wrist_twist" type="hinge" axis="0 0 1" range="-3.14159 3.14159" damping="0.5"/>
              <geom type="cylinder" size="0.025 0.015" material="arm_mat" mass="0.3"/>

              <!-- Claw base -->
              <body name="claw_base" pos="0 0 0.02">
                <geom type="box" size="0.02 0.03 0.01" material="claw_mat" mass="0.2"/>

                <!-- Left finger -->
                <body name="finger_left" pos="0 -0.025 0.01">
                  <joint name="claw" type="hinge" axis="1 0 0" range="0 1.2" damping="0.5"/>
                  <geom type="box" size="0.008 0.005 0.04" pos="0 0 0.04" material="claw_mat" mass="0.1"/>
                </body>

                <!-- Right finger (mirrors left) -->
                <body name="finger_right" pos="0 0.025 0.01">
                  <joint name="claw_right" type="hinge" axis="-1 0 0" range="0 1.2" damping="0.5"/>
                  <geom type="box" size="0.008 0.005 0.04" pos="0 0 0.04" material="claw_mat" mass="0.1"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <joint joint1="claw" joint2="claw_right" polycoef="0 1 0 0 0"/>
  </equality>

  <actuator>
    <motor name="base_slide_motor" joint="base_slide" gear="50" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="shoulder_motor" joint="shoulder" gear="30" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="elbow_motor" joint="elbow" gear="20" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="wrist_twist_motor" joint="wrist_twist" gear="5" ctrllimited="true" ctrlrange="-1 1"/>
    <motor name="claw_motor" joint="claw" gear="5" ctrllimited="true" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
