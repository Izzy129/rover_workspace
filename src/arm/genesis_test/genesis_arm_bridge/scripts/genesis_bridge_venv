#!/bin/bash
# Wrapper that runs the genesis bridge node using the genesis-env venv Python.
# This is necessary because ROS2 entry points use system Python, which has
# an incompatible coverage package that breaks numba (used by Genesis).

VENV_PYTHON="$HOME/genesis-env/bin/python3"

if [ ! -x "$VENV_PYTHON" ]; then
    echo "ERROR: Genesis venv not found at $VENV_PYTHON" >&2
    echo "Install Genesis in ~/genesis-env/ or update this script." >&2
    exit 1
fi

exec "$VENV_PYTHON" -m genesis_arm_bridge.bridge_node "$@"
