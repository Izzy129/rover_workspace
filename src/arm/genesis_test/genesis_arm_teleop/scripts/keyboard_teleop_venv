#!/bin/bash
# Wrapper that runs the keyboard teleop node using the genesis-env venv Python.
# evdev is installed in the venv, not system-wide.

VENV_PYTHON="$HOME/genesis-env/bin/python3"

if [ ! -x "$VENV_PYTHON" ]; then
    echo "ERROR: Genesis venv not found at $VENV_PYTHON" >&2
    exit 1
fi

exec "$VENV_PYTHON" -m genesis_arm_teleop.keyboard_node "$@"
